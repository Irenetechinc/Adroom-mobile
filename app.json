{
  "expo": {
    "name": "AdRoom AI",
    "slug": "adroom-mobile",
    "scheme": "adroom",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0F19"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.adroom.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.adroom.mobile",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#00F0FF",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "AdRoom uses your location to find local trends and optimize campaign targeting.",
          "locationWhenInUsePermission": "AdRoom uses your location to find local trends and optimize campaign targeting."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "gradleVersion": "8.10.2"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3b1fdc27-8b2b-4661-9f92-072a73d5425e"
      }
    }
  }
}
