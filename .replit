modules = ["nodejs-20", "web"]
[agent]
expertMode = true
integrations = ["javascript_database:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["eas-cli"]

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8000
externalPort = 8000

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx serve web-build -l 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && npm install --legacy-peer-deps && npx ts-node --transpile-only src/server.ts"
waitForPort = 8000

[deployment]
deploymentTarget = "static"
build = ["bash", "-c", "npx expo export --platform web --output-dir web-build"]
publicDir = "web-build"

[userenv]

[userenv.shared]
EXPO_PUBLIC_SUPABASE_URL = "https://mrrgjvrntenlkvslfvfh.supabase.co"
EXPO_PUBLIC_FACEBOOK_APP_ID = "1536532767602012"
EXPO_PUBLIC_TWITTER_CLIENT_ID = "uFUW0E3WZ5RnUwK4f4RlzRjBn"
EXPO_PUBLIC_MIN_DEPOSIT = "1000"
EXPO_PUBLIC_ADROOM_FEE = "45"
EXPO_PUBLIC_API_URL = "https://adroom-mobile-production-c7fb.up.railway.app"
PORT = "8000"
NODE_ENV = "production"
